<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ProjectHub.Desktop.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ProjectHub.Desktop.Views.AddWorkspaceDialog"
        Title="{Binding DialogTitle}"
        Width="800" Height="600"
        MaxWidth="900" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:AddWorkspaceDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="16">
            <TextBlock Text="工作区名称 *" FontWeight="SemiBold" />
            <TextBox Text="{Binding WorkspaceName}" 
                     Watermark="输入工作区名称..."
                     MaxLength="100" />
            
            <TextBlock Text="描述" FontWeight="SemiBold" />
            <TextBox Text="{Binding Description}" 
                     Watermark="输入描述（可选）..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80" />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,*,*" Margin="0,16,0,0">
            <TextBlock Grid.Row="0" 
                      Text="项目选择" 
                      FontWeight="SemiBold" />
            
            <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{Binding SearchQuery}" 
                             Watermark="搜索项目..."
                             Width="300" />
                    <Button Content="搜索" 
                            Command="{Binding SearchProjectsCommand}" />
                </StackPanel>
                
                <Border Grid.Row="1" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Margin="0,8,0,0"
                        Background="White">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding AvailableProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="12,8" 
                                            Margin="4"
                                            Background="#F8F9FA"
                                            CornerRadius="4"
                                            BorderThickness="0"
                                            Command="{Binding $parent[ItemsControl].((vm:AddWorkspaceDialogViewModel)DataContext).AddProjectCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Name}" 
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" 
                                                       Text="+" 
                                                       FontSize="16" 
                                                       Foreground="#2196F3" 
                                                       FontWeight="Bold" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="0,16,0,0">
                <TextBlock Grid.Row="0" 
                          Text="已选项目" 
                          FontWeight="SemiBold" />
                
                <Border Grid.Row="1" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Margin="0,8,0,0"
                        Background="White">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding SelectedProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" 
                                            Margin="4"
                                            Background="#E3F2FD"
                                            CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding Tags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#2196F3" 
                                                                    CornerRadius="12" 
                                                                    Padding="6,2"
                                                                    Margin="0,0,4,0">
                                                                <TextBlock Text="{Binding}" 
                                                                           FontSize="11" 
                                                                           Foreground="White" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <Button Grid.Column="1" 
                                                    Content="×" 
                                                    FontSize="16" 
                                                    Foreground="#e74c3c" 
                                                    FontWeight="Bold"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="4"
                                                    Click="OnRemoveProjectClicked"
                                                    Tag="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="8" 
                    Margin="0,20,0,0">
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="#e74c3c" 
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" 
                       IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="取消" 
                    Width="100" 
                    Click="OnCancelClicked" />
            <Button Content="保存" 
                    Width="100" 
                    Classes="Primary" 
                    Click="OnSaveClicked" />
        </StackPanel>
    </Grid>
</Window>
