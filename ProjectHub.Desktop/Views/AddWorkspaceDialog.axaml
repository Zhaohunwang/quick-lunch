<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ProjectHub.Desktop.ViewModels"
        xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:micons="clr-namespace:Material.Icons;assembly=Material.Icons"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ProjectHub.Desktop.Views.AddWorkspaceDialog"
        Title="{Binding DialogTitle}"
        Width="800" Height="680"
        MaxWidth="900" MaxHeight="780"
        Icon="avares://ProjectHub.Desktop/Assets/app-icon.ico"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:AddWorkspaceDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <icons:MaterialIcon Kind="BriefcaseOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="工作区名称 *" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox Text="{Binding WorkspaceName}" 
                     Watermark="输入工作区名称..."
                     MaxLength="100" />
            
            <StackPanel Orientation="Horizontal" Spacing="6">
                <icons:MaterialIcon Kind="Text" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="描述" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox Text="{Binding Description}" 
                     Watermark="输入描述（可选）..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80" />

            <StackPanel Orientation="Horizontal" Spacing="6">
                <icons:MaterialIcon Kind="MonitorDashboard" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="默认IDE（可选）" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <ComboBox ItemsSource="{Binding AvailableIdes}"
                      SelectedItem="{Binding SelectedIde}"
                      PlaceholderText="选择默认IDE..."
                      HorizontalAlignment="Left"
                      MinWidth="250">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <CheckBox Content="收藏工作区" IsChecked="{Binding IsFavorite}" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,*,*" Margin="0,16,0,0">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                <icons:MaterialIcon Kind="FolderOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="项目选择" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            
            <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{Binding SearchQuery}" 
                             Watermark="搜索项目..."
                             Width="300" />
                    <Button Content="搜索" 
                            Command="{Binding SearchProjectsCommand}" />
                </StackPanel>
                
                <Border Grid.Row="1" 
                        BorderBrush="{DynamicResource App.CardBorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Margin="0,8,0,0"
                        Background="{DynamicResource App.TextBoxBackgroundBrush}">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding AvailableProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="12,8" 
                                            Margin="4"
                                            Background="{DynamicResource App.SurfaceSecondaryBrush}"
                                            CornerRadius="4"
                                            BorderThickness="0"
                                            Command="{Binding $parent[ItemsControl].((vm:AddWorkspaceDialogViewModel)DataContext).AddProjectCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Name}" 
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" 
                                                       Text="+" 
                                                       FontSize="16" 
                                                       Foreground="{DynamicResource App.PrimaryBrush}" 
                                                       FontWeight="Bold" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="0,16,0,0">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                    <icons:MaterialIcon Kind="CheckCircleOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="已选项目" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Border Grid.Row="1" 
                        BorderBrush="{DynamicResource App.CardBorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Margin="0,8,0,0"
                        Background="{DynamicResource App.TextBoxBackgroundBrush}">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding SelectedProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" 
                                            Margin="4"
                                            Background="{DynamicResource App.NavigationActiveBackgroundBrush}"
                                            CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding Tags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource App.NavigationActiveIndicatorBrush}" 
                                                                    CornerRadius="12" 
                                                                    Padding="6,2"
                                                                    Margin="0,0,4,0">
                                                                <TextBlock Text="{Binding}" 
                                                                           FontSize="11" 
                                                                           Foreground="White" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <Button Grid.Column="1" 
                                                    Content="×" 
                                                    FontSize="16" 
                                                    Foreground="{DynamicResource App.DangerBrush}" 
                                                    FontWeight="Bold"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="4"
                                                    Click="OnRemoveProjectClicked"
                                                    Tag="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="8" 
                    Margin="0,20,0,0">
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="{DynamicResource App.DangerBrush}" 
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" 
                       IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="取消" 
                    Width="100" 
                    Click="OnCancelClicked" />
            <Button Content="保存" 
                    Width="100" 
                    Classes="PrimaryButton" 
                    Click="OnSaveClicked" />
        </StackPanel>
    </Grid>
</Window>
