<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ProjectHub.Desktop.ViewModels"
        xmlns:models="clr-namespace:ProjectHub.Core.Models;assembly=ProjectHub.Core"
        xmlns:templates="clr-namespace:ProjectHub.Desktop.Templates"
        xmlns:local="clr-namespace:ProjectHub.Desktop.Converters"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
        x:Class="ProjectHub.Desktop.MainWindow"
        x:Name="root"
        Title="Project Hub"
        Width="1000" Height="650"
        MinWidth="800" MinHeight="500">

    <Window.Styles>
        <Style Selector=".SelectedTagButton" x:SetterTargetType="Button">
            <Setter Property="Background" Value="#E3F2FD" />
            <Setter Property="Foreground" Value="#1976D2" />
            <Setter Property="BorderBrush" Value="#1976D2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Styles>
    
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>
    <Window.DataTemplates>
        <DataTemplate DataType="models:Project">
            <Border Background="LightBlue" Margin="0,5" Padding="10">
                <TextBlock Text="{Binding Name}" />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="models:Workspace">
            <Border Background="LightGreen" Margin="0,5" Padding="10">
                <TextBlock Text="{Binding Name}" />
            </Border>
        </DataTemplate>
    </Window.DataTemplates>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,1,0">
            <ScrollViewer>
                <StackPanel Margin="8">
                    <!-- 项目分组 -->
                    <TextBlock Text="项目" FontWeight="SemiBold" FontSize="12" Foreground="#6C757D" Margin="8,8,8,4" />
                    <ToggleButton Name="AllProjectsButton"
                            Content="{Binding AllProjectsText}" 
                            Classes="NavigationButton"
                            IsChecked="{Binding IsAllSelected}"
                            Command="{Binding ShowAllProjectsCommand}" />
                    <ToggleButton Name="FavoriteProjectsButton"
                            Content="{Binding FavoriteProjectsText}" 
                            Classes="NavigationButton"
                            IsChecked="{Binding IsFavoriteSelected}"
                            Command="{Binding ShowFavoriteProjectsCommand}" />
                    <ToggleButton Name="RecentProjectsButton"
                            Content="{Binding RecentProjectsText}" 
                            Classes="NavigationButton"
                            IsChecked="{Binding IsRecentSelected}"
                            Command="{Binding ShowRecentProjectsCommand}" />
                    
                    <!-- 分隔线 -->
                    <Separator Margin="8,12,8,12" Background="#E9ECEF" />
                    
                    <!-- 标签分组 -->
                    <Grid Margin="8,8,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="标签" FontWeight="SemiBold" FontSize="12" Foreground="#6C757D" />
                        <Button Grid.Column="1" Content="+" Classes="SmallButton" Command="{Binding AddTagCommand}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding DisplayTags}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.ContentTemplate>
                                        <templates:TagTemplateSelector />
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- 分隔线 -->
                    <Separator Margin="8,12,8,12" Background="#E9ECEF" />
                    
                    <!-- 工作区分组 -->
                    <Grid Margin="8,8,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="工作区" FontWeight="SemiBold" FontSize="12" Foreground="#6C757D" />
                        <Button Grid.Column="1" Content="+" Classes="SmallButton" Command="{Binding AddWorkspaceCommand}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Workspaces}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Classes="NavigationButton" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- 分隔线 -->
                    <Separator Margin="8,12,8,12" Background="#E9ECEF" />
                    
                    <!-- 设置 -->
                    <TextBlock Text="设置" FontWeight="SemiBold" FontSize="12" Foreground="#6C757D" Margin="8,8,8,4" />
                    <Button Content="⚙️ IDE设置" Classes="NavigationButton" Command="{Binding ShowIdeSettingsCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- 右侧内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- 工具栏 -->
            <Border Grid.Row="0" Background="#FFFFFF" Padding="16,12" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- 搜索框 -->
                    <TextBox Grid.Column="0" 
                             x:Name="SearchTextBox" 
                             Text="{Binding SearchQuery}"
                             Watermark="🔍 搜索项目..." 
                             Width="300"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged" />
                    
                    <!-- 右侧按钮组 -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Spacing="8">
                        <Button Content="🚀 快速启动" Classes="ToolButton" Command="{Binding QuickLaunchCommand}" ToolTip.Tip="快速打开最近访问的项目" />
                        <Button Content="⚙️ IDE设置" Classes="ToolButton" Command="{Binding ShowIdeSettingsCommand}" />
                        <Button Click="AddProjectButton_Click" 
                                Content="+" 
                                FontWeight="Bold" 
                                FontSize="18" 
                                Width="36" 
                                Height="36"
                                Classes="PrimaryButton" />
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 主内容区 -->
            <ScrollViewer Grid.Row="1" Background="#FFFFFF">
                <StackPanel Margin="16">
                    <!-- 全部项目区域 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="📁 全部项目" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" />
                        
                        <!-- 视图切换按钮 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <ToggleButton Content="□" Classes="ViewButton" ToolTip.Tip="卡片视图" IsChecked="{Binding CurrentViewMode, Converter={x:Static local:StringEqualsConverter.Instance}, ConverterParameter='card'}" Command="{Binding ChangeViewModeCommand}" CommandParameter="card" />
                            <ToggleButton Content="▤" Classes="ViewButton" ToolTip.Tip="列表视图" IsChecked="{Binding CurrentViewMode, Converter={x:Static local:StringEqualsConverter.Instance}, ConverterParameter='list'}" Command="{Binding ChangeViewModeCommand}" CommandParameter="list" />
                            <ToggleButton Content="☰" Classes="ViewButton" ToolTip.Tip="紧凑视图" IsChecked="{Binding CurrentViewMode, Converter={x:Static local:StringEqualsConverter.Instance}, ConverterParameter='compact'}" Command="{Binding ChangeViewModeCommand}" CommandParameter="compact" />
                        </StackPanel>
                    </Grid>
                    
                    <!-- 项目列表 -->
                    <Grid>
                        <!-- 卡片模式：多列显示 -->
                        <ItemsControl ItemsSource="{Binding FilteredItems}" 
                                     IsVisible="{Binding CurrentViewMode, Converter={x:Static local:StringEqualsConverter.Instance}, ConverterParameter='card'}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Top" 
                                              Margin="0,8,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFF" 
                                            BorderBrush="#E9ECEF" 
                                            BorderThickness="1" 
                                            CornerRadius="8"
                                            Width="250"
                                            Margin="8" 
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- 第一行：图标 + 名称 + 收藏 + 操作按钮 -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 项目/工作区图标 -->
                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Converter={x:Static local:ItemTypeToIconConverter.Instance}}" 
                                                           FontSize="24" 
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                                
                                                <!-- 名称和别名 -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" 
                                                               FontSize="18" 
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Alias, StringFormat=' ({0})'}" 
                                                               FontSize="14" 
                                                               Foreground="#6C757D"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding Alias, Converter={x:Static local:StringIsNotNullOrEmptyConverter.Instance}}"/>
                                                </StackPanel>
                                                
                                                <!-- 收藏按钮 -->
                                                <Button Grid.Column="2" 
                                                        Content="{Binding IsFavorite, Converter={x:Static local:BoolToFavoriteIconConverter.Instance}}" 
                                                        Classes="IconButton"
                                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="8,0"/>
                                                
                                                <!-- 更多操作 -->
                                                <Button Grid.Column="3"
                                                        Content="⋮"
                                                        Classes="IconButton"
                                                        ToolTip.Tip="更多操作"
                                                        Tag="{Binding}"
                                                        Click="OnMoreOptionsClick">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="编辑"
                                                                      Command="{Binding EditProjectCommand}" />
                                                            <MenuItem Header="删除"
                                                                      Command="{Binding DeleteProjectCommand}" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </Grid>
                                            
                                            <!-- 第二行：描述 -->
                                            <TextBlock Grid.Row="1" 
                                                       Text="{Binding Description}" 
                                                       FontSize="13"
                                                       Foreground="#6C757D"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="2"
                                                       Margin="0,8,0,0"
                                                       IsVisible="{Binding Description, Converter={x:Static local:StringIsNotNullOrEmptyConverter.Instance}}"/>
                                            
                                            <!-- 第三行：标签 -->
                                            <ItemsControl Grid.Row="2" 
                                                          ItemsSource="{Binding Tags, Converter={x:Static local:TagsToLimitedConverter.Instance}, ConverterParameter='10'}"
                                                          Margin="0,12,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#E3F2FD" 
                                                                CornerRadius="4" 
                                                                Padding="6,3">
                                                            <TextBlock Text="{Binding}" 
                                                                       FontSize="12" 
                                                                       Foreground="#1976D2"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <!-- 第四行：路径和打开时间 + IDE按钮 -->
                                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0" Orientation="Vertical">
                                                    <TextBlock Text="{Binding Path}" 
                                                               FontSize="11" 
                                                               Foreground="#ADB5BD"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding LastOpenedAt, Converter={x:Static local:DateTimeToRelativeConverter.Instance}}" 
                                                               FontSize="11" 
                                                               Foreground="#ADB5BD"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <!-- 默认IDE启动按钮 -->
                                                <Button Grid.Column="1" 
                                                        Content="{Binding Converter={x:Static local:DefaultIdeConverter.Instance}}"
                                                        Classes="IdeButton"
                                                        ToolTip.Tip="使用默认IDE打开项目"
                                                        Command="{Binding DataContext.LaunchProjectCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- 列表模式：单列显示 -->
                        <ItemsControl ItemsSource="{Binding FilteredItems}" 
                                     IsVisible="{Binding CurrentViewMode, Converter={x:Static local:StringEqualsConverter.Instance}, ConverterParameter='list'}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel VerticalAlignment="Top" 
                                               Margin="0,8,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFF" 
                                            BorderBrush="#E9ECEF" 
                                            BorderThickness="0,0,0,1" 
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,0"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- 图标 -->
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Converter={x:Static local:ItemTypeToIconConverter.Instance}}" 
                                                       FontSize="18" 
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>
                                            
                                            <!-- 名称和别名 -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="14" 
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Alias, StringFormat=' ({0})'}" 
                                                           FontSize="12" 
                                                           Foreground="#6C757D"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding Alias, Converter={x:Static local:StringIsNotNullOrEmptyConverter.Instance}}"/>
                                                
                                                <!-- 标签（最多3个） -->
                                                <ItemsControl ItemsSource="{Binding Tags, Converter={x:Static local:TagsToLimitedConverter.Instance}, ConverterParameter='3'}"
                                                              Margin="12,0,0,0"
                                                              VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#E3F2FD" 
                                                                    CornerRadius="3" 
                                                                    Padding="4,2">
                                                                <TextBlock Text="{Binding}" 
                                                                           FontSize="10" 
                                                                           Foreground="#1976D2"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            
                                            <!-- 操作列 -->
                                            <StackPanel Grid.Column="3" 
                                                        Orientation="Horizontal" 
                                                        Spacing="4">
                                                <Button Content="{Binding Converter={x:Static local:DefaultIdeConverter.Instance}}" 
                                                        Classes="SmallIconButton"
                                                        ToolTip.Tip="使用默认IDE打开"
                                                        Command="{Binding DataContext.LaunchProjectCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="{Binding IsFavorite, Converter={x:Static local:BoolToFavoriteIconConverter.Instance}}" 
                                                        Classes="SmallIconButton"
                                                        ToolTip.Tip="收藏项目"
                                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                        CommandParameter="{Binding}"/>
                                                <!-- 更多操作（IDE子菜单在code-behind动态注入） -->
                                                <Button Content="⋮" 
                                                        Classes="SmallIconButton"
                                                        ToolTip.Tip="更多操作"
                                                        Tag="{Binding}"
                                                        Click="OnMoreOptionsClick">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="编辑" 
                                                                      Command="{Binding EditProjectCommand}" 
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                                            <MenuItem Header="删除" 
                                                                      Command="{Binding DeleteProjectCommand}" 
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- 紧凑模式：单列显示 -->
                        <ItemsControl ItemsSource="{Binding FilteredItems}" 
                                     IsVisible="{Binding CurrentViewMode, Converter={x:Static local:StringEqualsConverter.Instance}, ConverterParameter='compact'}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel VerticalAlignment="Top" 
                                               Margin="0,8,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFF" 
                                            BorderBrush="#E9ECEF" 
                                            BorderThickness="0,0,0,1" 
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,0"
                                            Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- 收藏图标 -->
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding IsFavorite, Converter={x:Static local:BoolToFavoriteIconConverter.Instance}}" 
                                                       FontSize="12" 
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            
                                            <!-- 名称 -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Name}" 
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            
                                            <!-- 打开按钮 -->
                                            <Button Grid.Column="2" 
                                                    Content="{Binding Converter={x:Static local:DefaultIdeConverter.Instance}}"
                                                    Classes="SmallIconButton"
                                                    ToolTip.Tip="使用默认IDE打开"
                                                    Command="{Binding DataContext.LaunchProjectCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                    CommandParameter="{Binding}">
                                                <Button.ContextMenu>
                                                    <ContextMenu x:Name="CompactItemContextMenu">
                                                        <MenuItem Header="编辑" 
                                                                  Command="{Binding EditProjectCommand}" 
                                                                  CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                                        <MenuItem Header="删除" 
                                                                  Command="{Binding DeleteProjectCommand}" 
                                                                  CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
