<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
    </Style>

    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="{DynamicResource App.TextBoxBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.TextBoxBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.NavigationButton">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="3,*">
                    <Border x:Name="Indicator"
                            Grid.Column="0"
                            Width="3"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            Margin="0,6,0,6"
                            Opacity="0"
                            Background="{DynamicResource App.NavigationActiveIndicatorBrush}" />
                    <Border x:Name="PART_Border"
                            Grid.Column="1"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.NavigationButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.NavigationButton.active">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource App.NavigationActiveTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="3,*">
                    <Border x:Name="Indicator"
                            Grid.Column="0"
                            Width="3"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            Margin="0,6,0,6"
                            Opacity="1"
                            Background="{DynamicResource App.NavigationActiveIndicatorBrush}" />
                    <Border x:Name="PART_Border"
                            Grid.Column="1"
                            Background="{DynamicResource App.NavigationActiveBackgroundBrush}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.NavigationButton.active:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.12" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.ToolButton">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource App.SecondaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.ToolButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.ToolButton:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background" Value="{DynamicResource App.PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.PrimaryButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource App.PrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.PrimaryButton:pressed /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource App.PrimaryPressedBrush}" />
    </Style>

    <Style Selector="Button.SmallButton">
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="MinWidth" Value="50" />
    </Style>

    <Style Selector="Button.DangerButton">
        <Setter Property="Background" Value="{DynamicResource App.DangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.DangerButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style Selector="Border.IdeListItem">
        <Setter Property="Background" Value="{DynamicResource App.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style Selector="Border.IdeListItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource App.HoverSurfaceBrush}" />
    </Style>

    <Style Selector="Border.IdeListItem.selected">
        <Setter Property="BorderBrush" Value="{DynamicResource App.PrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource App.NavigationActiveBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="1,1,3,1" />
    </Style>

    <Style Selector="Border.SearchButton">
        <Setter Property="Background" Value="{DynamicResource App.TextBoxBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.TextBoxBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style Selector="Border.SearchButton:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource App.PrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource App.HoverSurfaceBrush}" />
    </Style>

    <Style Selector="Border.IdeCard">
        <Setter Property="Background" Value="{DynamicResource App.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style Selector="Border.IdeCard:pointerover">
        <Setter Property="Background" Value="{DynamicResource App.HoverSurfaceBrush}" />
    </Style>

    <Style Selector="Border.IdeCard.running">
        <Setter Property="BorderBrush" Value="{DynamicResource App.PrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource App.NavigationActiveBackgroundBrush}" />
    </Style>

    <Style Selector="Border.IdeCard.selected">
        <Setter Property="BorderBrush" Value="{DynamicResource App.PrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource App.NavigationActiveBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="1,1,3,1" />
    </Style>

    <Style Selector="Button.ViewButton">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource App.SecondaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.ViewButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.ViewButton:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.ViewButton.active">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{DynamicResource App.NavigationActiveBackgroundBrush}"
                        BorderBrush="{DynamicResource App.PrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.ViewButton.active:pointerover /template/ Border#PART_Border">
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style Selector="Button.IdeButton">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.IdeButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.IdeButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.IdeButton:pressed /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.IconButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="{DynamicResource App.SecondaryTextBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.IconButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.IconButton:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.IconButton:pressed /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.SmallIconButton">
        <Setter Property="MinWidth" Value="26" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="Transparent"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.SmallIconButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource App.HoverSurfaceColor}" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.PlayButton">
        <Setter Property="Background" Value="{DynamicResource App.PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.PlayButton:pointerover /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource App.PrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.PlayButton:pressed /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource App.PrimaryPressedBrush}" />
    </Style>

    <Style Selector="Menu">
        <Setter Property="Background" Value="{DynamicResource App.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.MenuBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
    </Style>

    <Style Selector="MenuItem:selected /template/ ContentPresenter#root">
        <Setter Property="Background" Value="{DynamicResource App.MenuHoverBrush}" />
    </Style>

    <Style Selector="TextBlock.Title">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource App.PrimaryTextBrush}" />
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource App.BorderBrush}" />
    </Style>

</Styles>
