<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 全局样式 -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Background" Value="#FFFFFF" />
    </Style>
    
    <!-- 按钮基础样式 -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#F0F0F0" />
        <Setter Property="BorderBrush" Value="#D0D0D0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="#E0E0E0" />
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="#D0D0D0" />
    </Style>
    
    <!-- 文本框样式 -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#E9ECEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#0078D4" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    
    <!-- 左侧导航栏按钮样式 -->
    <Style Selector="Button.NavigationButton">
        <Setter Property="Margin" Value="0,2,0,2" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="#495057" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.NavigationButton:pointerover">
        <Setter Property="Background" Value="#E9ECEF" />
        <Setter Property="Foreground" Value="#212529" />
    </Style>
    <Style Selector="Button.NavigationButton:pressed">
        <Setter Property="Background" Value="#DEE2E6" />
    </Style>
    <Style Selector="Button.NavigationButton.Active">
        <Setter Property="Background" Value="#0078D4" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.NavigationButton[Tag=True]">
        <Setter Property="Background" Value="#0078D4" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    
    <!-- 工具栏按钮样式 -->
    <Style Selector="Button.ToolButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#E9ECEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="#495057" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.ToolButton:pointerover">
        <Setter Property="Background" Value="#F8F9FA" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
    </Style>
    
    <!-- 主要按钮样式 -->
    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background" Value="#0078D4" />
        <Setter Property="BorderBrush" Value="#0078D4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="Button.PrimaryButton:pointerover">
        <Setter Property="Background" Value="#106EBE" />
    </Style>
    <Style Selector="Button.PrimaryButton:pressed">
        <Setter Property="Background" Value="#005A9E" />
    </Style>
    
    <!-- 小按钮样式 -->
    <Style Selector="Button.SmallButton">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="#E9ECEF" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Foreground" Value="#495057" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.SmallButton:pointerover">
        <Setter Property="Background" Value="#DEE2E6" />
        <Setter Property="Foreground" Value="#212529" />
    </Style>
    <Style Selector="Button.SmallButton:pressed">
        <Setter Property="Background" Value="#CED4DA" />
    </Style>
    
    <!-- 危险按钮样式 -->
    <Style Selector="Button.DangerButton">
        <Setter Property="Background" Value="#DC3545" />
        <Setter Property="BorderBrush" Value="#DC3545" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.DangerButton:pointerover">
        <Setter Property="Background" Value="#C82333" />
    </Style>
    <Style Selector="Button.DangerButton:pressed">
        <Setter Property="Background" Value="#BD2130" />
    </Style>
    
    <!-- IDE列表项样式 -->
    <Style Selector="Button.IdeListItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#E9ECEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#495057" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.IdeListItem:pointerover">
        <Setter Property="Background" Value="#F8F9FA" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
    </Style>
    <Style Selector="Button.IdeListItem:pressed">
        <Setter Property="Background" Value="#E9ECEF" />
    </Style>
    
    <!-- 视图切换按钮样式 -->
    <Style Selector="Button.ViewButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#E9ECEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#6C757D" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Button.ViewButton:pointerover">
        <Setter Property="Background" Value="#F8F9FA" />
        <Setter Property="Foreground" Value="#495057" />
    </Style>
    <Style Selector="Button.ViewButton:pressed">
        <Setter Property="Background" Value="#E9ECEF" />
    </Style>
    
    <!-- IDE选择按钮样式 -->
    <Style Selector="Button.IdeButton">
        <Setter Property="Background" Value="#F8F9FA" />
        <Setter Property="BorderBrush" Value="#E9ECEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#495057" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.IdeButton:pointerover">
        <Setter Property="Background" Value="#E9ECEF" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
    </Style>
    
    <!-- 打开项目按钮样式 -->
    <Style Selector="Button.PlayButton">
        <Setter Property="Background" Value="#28A745" />
        <Setter Property="BorderBrush" Value="#28A745" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.PlayButton:pointerover">
        <Setter Property="Background" Value="#218838" />
    </Style>
    <Style Selector="Button.PlayButton:pressed">
        <Setter Property="Background" Value="#1E7E34" />
    </Style>
    
    <!-- 菜单样式 -->
    <Style Selector="Menu">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#E9ECEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="4" />
    </Style>
    
    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="MenuItem:pointerover">
        <Setter Property="Background" Value="#F8F9FA" />
    </Style>
    
    <Style Selector="MenuItem.IdeMenuItem">
        <Setter Property="Background" Value="#0078D4" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="MenuItem.IdeMenuItem:pointerover">
        <Setter Property="Background" Value="#106EBE" />
    </Style>
    
    <!-- 标题样式 -->
    <Style Selector="TextBlock.Title">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#6C757D" />
        <Setter Property="Margin" Value="8,8,8,4" />
    </Style>
    
    <!-- 分隔线样式 -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="#E9ECEF" />
        <Setter Property="Margin" Value="8,12,8,12" />
    </Style>
</Styles>
